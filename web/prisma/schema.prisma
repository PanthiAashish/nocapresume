generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ResumeUpload {
  id                  String   @id @default(cuid())
  userEmail           String
  filename            String
  mimeType            String
  bytes               Bytes
  extractedText       String?
  textExtractionError String?
  createdAt           DateTime @default(now())

  @@index([userEmail, createdAt])
}

model JobDescriptionEntry {
  id        String   @id @default(cuid())
  userEmail String
  content   String
  createdAt DateTime @default(now())

  @@index([userEmail, createdAt])
}
